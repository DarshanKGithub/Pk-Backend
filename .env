# ===========================================
# PK CORPORATE ERP — BACKEND ENV VARIABLES
# ===========================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.

# SERVER
PORT=9090

# DATABASE (PostgreSQL)
DB_URL=jdbc:postgresql://ep-twilight-darkness-axjl2tjl-pooler.c-4.us-east-2.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=npg_qi9VlgUZ2jND

# JWT SECURITY
JWT_SECRET=your_very_long_random_secret_at_least_256_bits
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# CLOUDINARY (required for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# EMAIL / SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# FILE UPLOAD LIMITS
MAX_FILE_SIZE=15MB
MAX_REQUEST_SIZE=15MB

# FRONTEND CORS ORIGINS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# CSP CONNECT-SRC (space-separated backend + frontend origins)
CSP_CONNECT_SRC=http://localhost:9090 http://localhost:3000 http://localhost:5173

# PRODUCTION SAFETY FLAGS
# Set DDL_AUTO=validate in production after the schema is stable
DDL_AUTO=update
# Set SEED_ENABLED=false in production after first deploy
SEED_ENABLED=true
# Set a strong admin seed password (only used when DB is empty)
ADMIN_SEED_PASSWORD=your_strong_admin_password